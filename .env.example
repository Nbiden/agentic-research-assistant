# Agentic Research Assistant — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.

# === Required ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
TAVILY_API_KEY=tvly-your-key-here

# === Optional (defaults shown) ===
CLAUDE_MODEL=claude-sonnet-4-20250514
LOG_LEVEL=INFO

# FAISS knowledge base paths (leave blank to disable KB tool)
FAISS_INDEX_PATH=./data/knowledge_base.index
FAISS_DOCUMENTS_PATH=./data/documents.pkl

# Retry configuration for external tool calls
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0
